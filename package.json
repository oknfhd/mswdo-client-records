{
  "name": "mswd_clients",
  "version": "1.2.1",
  "description": "",
  "main": "main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "vite": "^8.0.9",
    "wait-on": "^9.0.5"
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "docxtemplater": "^3.68.5",
    "pizzip": "^3.2.0"
  },
  "build": {
    "appId": "com.mswdclients.app",
    "productName": "MSWD Clients",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "public/template",
        "to": "template"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
